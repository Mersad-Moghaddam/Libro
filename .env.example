# Docker Compose / monorepo-level configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=negar
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_PORT=3306
REDIS_PORT=6379

# Frontend
VITE_API_URL=http://localhost:8080/api/v1

# Backend runtime defaults (mirrors backend/dev.env)
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=debug
JWT_SECRET=dev-secret-change-me-at-least-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=negar
MYSQL_PORT=3306
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
AUTH_RATE_LIMIT_WINDOW=1m
AUTH_RATE_LIMIT_MAX=20
FRONTEND_URL=http://localhost:5173
